{
  "name": "emoji-war-live",
  "version": "1.0.0",
  "description": "EMOJI WAR — YouTube Live Interactive Battle Game",
  "main": "server.js",
  "scripts": {
    "start":     "node server.js",
    "dev":       "node server.js",
    "token":     "node get_token.js",
    "pm2-start": "pm2 start server.js --name emoji-war --restart-delay=3000",
    "pm2-stop":  "pm2 stop emoji-war",
    "pm2-logs":  "pm2 logs emoji-war"
  },
  "dependencies": {
    "axios":       "^1.6.0",
    "dotenv":      "^16.3.0",
    "express":     "^4.18.0",
    "googleapis":  "^140.0.0",
    "node-cron":   "^3.0.0",
    "socket.io":   "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
